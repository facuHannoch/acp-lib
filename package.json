{
  "name": "@qlairoslabs/acp-client",
  "version": "0.1.0",
  "description": "Embeddable Agent Client Protocol (ACP) client library with degraded PTY fallback.",
  "type": "module",
  "module": "src/index.ts",
  "license": "MIT",
  "author": "Facundo Hannoch <ffacu594@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/facuHannoch/acp-lib.git"
  },
  "homepage": "https://github.com/facuHannoch/acp-lib#readme",
  "bugs": {
    "url": "https://github.com/facuHannoch/acp-lib/issues"
  },
  "keywords": [
    "acp",
    "agnostic acp client",
    "agent-client-protocol",
    "ai-agent",
    "coding-agent",
    "jsonrpc",
    "codex",
    "claude",
    "kimi",
    "opencode",
    "repl",
    "bun"
  ],
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./repl": "./src/repl/index.ts",
    "./degraded": "./src/degraded/index.ts",
    "./parser": "./src/parser/index.ts",
    "./cli": "./src/cli/index.ts"
  },
  "bin": {
    "acp-client": "./src/cli/index.ts"
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "check": "bun run typecheck && bun test",
    "pack:dry": "bun pm pack --dry-run"
  },
  "engines": {
    "bun": ">=1.3.5"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "0.25.1",
    "@xterm/headless": "^6.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
